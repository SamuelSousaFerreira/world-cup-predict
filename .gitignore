# Ambiente virtual e bytecode
venv/
__pycache__/
*.pyc
*.pyo

# Dados brutos — baixados automaticamente por data_collection.py
data/raw/

# Dataset de treino completo — grande e regenerável via train.py
data/processed/training_data.csv

# Logs e artefatos temporários do CatBoost
catboost_info/

# Arquivos que DEVEM ser commitados (necessários para o deploy):
#   models/*.joblib          — modelos treinados (~26 MB no total)
#   data/processed/team_state.json  — estado atual das seleções
#   data/squad/              — cache do Transfermarkt
